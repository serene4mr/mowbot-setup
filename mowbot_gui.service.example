[Unit]
Description=MowBot GUI + Stack
After=docker.service
Requires=docker.service

[Service]
Type=simple
# User/Group are overwritten by scripts/install.sh to match the installing account.
User=
Group=
# User= does not inherit docker group membership unless listed here (docker.sock access).
SupplementaryGroups=docker
WorkingDirectory=%h/mowbot-setup
Environment=HOME=%h
Environment=DISPLAY=:0
# Detect Xauthority at start time and write a runtime env file.
ExecStartPre=/bin/bash -c 'uid=$(id -u); if [ -f "/run/user/$uid/gdm/Xauthority" ]; then echo "XAUTHORITY=/run/user/$uid/gdm/Xauthority" > /run/mowbot-xauth.env; elif [ -f "$HOME/.Xauthority" ]; then echo "XAUTHORITY=$HOME/.Xauthority" > /run/mowbot-xauth.env; else for f in /run/user/$uid/.mutter-Xwaylandauth.*; do [ -f "$f" ] && echo "XAUTHORITY=$f" > /run/mowbot-xauth.env && break; done; fi'
EnvironmentFile=-/run/mowbot-xauth.env
ExecStartPre=/bin/bash -c 'if [ -S /tmp/.X11-unix/X0 ]; then /usr/bin/xhost +local:docker || true; fi'
ExecStart=/usr/libexec/docker/cli-plugins/docker-compose --env-file mowbot.env -f docker-compose.yml up mowbot_gui
ExecStop=/usr/libexec/docker/cli-plugins/docker-compose --env-file mowbot.env -f docker-compose.yml stop -t 30 mowbot_gui
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
